{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "autoIncrement": true
      },
      "autoSubmit": true,
      "submittedProfile": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "articfoxy@icloud.com",
        "ascAppId": "",
        "appleTeamId": "FPW3JJCJCW"
      }
    }
  }
}
